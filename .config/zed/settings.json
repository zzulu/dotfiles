{
  "git_panel": {
    "dock": "left"
  },
  "gutter": {
    "breakpoints": false
  },
  "format_on_save": "off",
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "seed_search_query_from_cursor": "selection",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "disable_ai": false,
  "edit_predictions": {
    "provider": "copilot"
  },
  "vim_mode": false,
  "base_keymap": "SublimeText",
  "cursor_blink": false,
  "relative_line_numbers": "disabled",
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 14,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vertical_scroll_margin": 8,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark"
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "vim": {
    "use_system_clipboard": "on_yank"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false
  },
  "outline_panel": {
    "dock": "left",
    "button": false
  },
  "double_click_in_multibuffer": "open",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "title_bar": {
    "show_sign_in": false
  },
}
